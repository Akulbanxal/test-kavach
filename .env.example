# KavachAI Environment Configuration Example
# Copy this file to .env and fill in the values

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Google Cloud / Vertex AI ─────────────────────────────────────────────────
# Your Google Cloud project ID (billing + Vertex AI API must be enabled)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Vertex AI region (us-central1 recommended for widest model availability)
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini model for inference (Gemini 2.5 generation required)
# Verified working: gemini-2.5-flash | gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# ─── Embedding ────────────────────────────────────────────────────────────────
# Vertex AI text embedding model (falls back to LocalSemanticEmbeddingProvider on 429)
# Verified working: text-embedding-004 | text-embedding-005
EMBEDDING_MODEL=text-embedding-004

# ─── Application Tuning ───────────────────────────────────────────────────────
# Minimum similarity % to include a scam match in results (0–100)
SIMILARITY_THRESHOLD_PCT=5
